<?xml version="1.0" encoding="utf-8"?>
<brls:Box
    id="player/container"
    width="100%"
    height="100%"
    axis="column"
    justifyContent="flexEnd"
    alignItems="stretch">

    <!-- Video display area - fills entire screen -->
    <vitaplex:VideoView
        id="player/video"
        width="100%"
        height="100%"
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        positionRight="0"
        positionBottom="0"
        visibility="gone"/>

    <!-- Photo display area (for photos) -->
    <brls:Image
        id="player/photo"
        width="100%"
        height="100%"
        scalingType="fit"
        visibility="gone"
        grow="1"/>

    <!-- Album art for music (centered above controls) -->
    <brls:Box
        width="100%"
        grow="1"
        axis="column"
        justifyContent="center"
        alignItems="center">
        <brls:Image
            id="player/album_art"
            width="200"
            height="200"
            scalingType="fit"
            cornerRadius="8"
            visibility="gone"/>
    </brls:Box>

    <!-- Controls overlay - positioned at bottom -->
    <brls:Box
        id="player/controls"
        width="100%"
        axis="column"
        alignItems="stretch"
        padding="15"
        backgroundColor="#80000000"
        cornerRadius="8"
        marginLeft="20"
        marginRight="20"
        marginBottom="20">

        <!-- Title -->
        <brls:Label
            id="player/title"
            text="Now Playing"
            fontSize="20"
            marginBottom="5"/>

        <!-- Artist (for music) -->
        <brls:Label
            id="player/artist"
            text=""
            fontSize="16"
            textColor="#AAAAAA"
            marginBottom="5"
            visibility="gone"/>

        <!-- Queue info (track X of Y, shuffle/repeat status) -->
        <brls:Label
            id="player/queue_info"
            text=""
            fontSize="12"
            textColor="#888888"
            marginBottom="8"
            visibility="gone"/>

        <!-- Progress slider (taller for easier touch) -->
        <brls:Slider
            id="player/progress"
            width="100%"
            height="40"
            marginBottom="5"/>

        <!-- Time display -->
        <brls:Label
            id="player/time"
            text="00:00 / 00:00"
            fontSize="14"
            horizontalAlign="center"
            marginBottom="8"/>

        <!-- Touch-friendly control buttons row -->
        <brls:Box
            width="100%"
            axis="row"
            justifyContent="center"
            alignItems="center">

            <!-- Audio track / Shuffle button -->
            <brls:Box
                id="player/audio_btn"
                width="80"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="8"
                backgroundColor="#40FFFFFF"
                marginRight="10"
                focusable="true"
                visibility="gone">
                <brls:Label
                    id="player/audio_label"
                    text="Audio"
                    fontSize="13"
                    textColor="#CCCCCC"/>
            </brls:Box>

            <!-- Rewind / Previous button -->
            <brls:Box
                id="player/rewind_btn"
                width="56"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="8"
                backgroundColor="#40FFFFFF"
                marginRight="10"
                focusable="true">
                <brls:Label
                    id="player/rewind_label"
                    text="<<"
                    fontSize="18"
                    textColor="#CCCCCC"/>
            </brls:Box>

            <!-- Play/Pause button -->
            <brls:Box
                id="player/play_btn"
                width="72"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="8"
                backgroundColor="#60E5A00D"
                marginRight="10"
                focusable="true">
                <brls:Label
                    id="player/play_pause_label"
                    text="Pause"
                    fontSize="15"
                    textColor="#FFFFFF"/>
            </brls:Box>

            <!-- Forward / Next button -->
            <brls:Box
                id="player/forward_btn"
                width="56"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="8"
                backgroundColor="#40FFFFFF"
                marginRight="10"
                focusable="true">
                <brls:Label
                    id="player/forward_label"
                    text=">>"
                    fontSize="18"
                    textColor="#CCCCCC"/>
            </brls:Box>

            <!-- Subtitle / Repeat button -->
            <brls:Box
                id="player/sub_btn"
                width="80"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="8"
                backgroundColor="#40FFFFFF"
                focusable="true"
                visibility="gone">
                <brls:Label
                    id="player/sub_label"
                    text="Subs"
                    fontSize="13"
                    textColor="#CCCCCC"/>
            </brls:Box>

        </brls:Box>

    </brls:Box>

</brls:Box>
